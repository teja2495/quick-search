<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-feature
        android:name="android.hardware.telephony"
        android:required="false" />
    <uses-feature
        android:name="android.hardware.telephony.calling"
        android:required="false" />

    <!-- Network Permissions -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Haptic Feedback -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Usage Statistics Permissions -->
    <uses-permission
        android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />

    <!-- Package Management Permissions -->
    <uses-permission
        android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission" />
    <uses-permission android:name="android.permission.REQUEST_DELETE_PACKAGES" />

    <!-- Contact Permissions -->
    <uses-permission android:name="android.permission.READ_CONTACTS" />
    <uses-permission android:name="android.permission.CALL_PHONE" />
    <uses-permission android:name="android.permission.READ_CALENDAR" />

    <!-- Storage Permissions -->
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission
        android:name="android.permission.MANAGE_EXTERNAL_STORAGE"
        tools:ignore="ScopedStorage" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />

    <queries>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <category android:name="android.intent.category.BROWSABLE" />
            <data android:scheme="http" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <category android:name="android.intent.category.BROWSABLE" />
            <data android:scheme="https" />
        </intent>
    </queries>

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.QuickSearch">

        <!-- Enable profiling for Android Profiler -->
        <profileable
            android:shell="true"
            android:enabled="true" />

        <!-- Main Activity -->
        <activity
            android:name=".app.MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:excludeFromRecents="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.QuickSearch"
            android:windowSoftInputMode="stateAlwaysVisible|adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.ASSIST" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.PROCESS_TEXT" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>
            <meta-data
                android:name="android.app.shortcuts"
                android:resource="@xml/shortcuts" />
        </activity>

        <activity-alias
            android:name=".app.MainActivityAliasDefault"
            android:enabled="true"
            android:exported="true"
            android:icon="@mipmap/ic_launcher"
            android:roundIcon="@mipmap/ic_launcher_round"
            android:label="@string/app_name"
            android:targetActivity=".app.MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".app.MainActivityAliasMonochromeLight"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_monochrome_light"
            android:roundIcon="@mipmap/ic_launcher_monochrome_light"
            android:label="@string/app_name"
            android:targetActivity=".app.MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".app.MainActivityAliasMonochromeDark"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_monochrome_dark"
            android:roundIcon="@mipmap/ic_launcher_monochrome_dark"
            android:label="@string/app_name"
            android:targetActivity=".app.MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".app.MainActivityAliasForestLight"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_forest_light"
            android:roundIcon="@mipmap/ic_launcher_forest_light"
            android:label="@string/app_name"
            android:targetActivity=".app.MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".app.MainActivityAliasForestDark"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_forest_dark"
            android:roundIcon="@mipmap/ic_launcher_forest_dark"
            android:label="@string/app_name"
            android:targetActivity=".app.MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".app.MainActivityAliasAuroraLight"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_aurora_light"
            android:roundIcon="@mipmap/ic_launcher_aurora_light"
            android:label="@string/app_name"
            android:targetActivity=".app.MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".app.MainActivityAliasAuroraDark"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_aurora_dark"
            android:roundIcon="@mipmap/ic_launcher_aurora_dark"
            android:label="@string/app_name"
            android:targetActivity=".app.MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".app.MainActivityAliasSunsetLight"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_sunset_light"
            android:roundIcon="@mipmap/ic_launcher_sunset_light"
            android:label="@string/app_name"
            android:targetActivity=".app.MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".app.MainActivityAliasSunsetDark"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_sunset_dark"
            android:roundIcon="@mipmap/ic_launcher_sunset_dark"
            android:label="@string/app_name"
            android:targetActivity=".app.MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <!-- Search Activities -->
        <activity
            android:name=".overlay.OverlayActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:launchMode="singleTask"
            android:theme="@style/Theme.QuickSearch"
            android:windowSoftInputMode="stateAlwaysVisible|adjustResize" />

        <activity
            android:name=".searchEngines.SearchTargetQueryShortcutActivity"
            android:exported="true"
            android:excludeFromRecents="true"
            android:noHistory="true"
            android:theme="@style/Theme.QuickSearch" />

        <!-- Widget Activities -->
        <activity
            android:name=".widgets.searchWidget.SearchWidgetConfigureActivity"
            android:exported="false"
            android:label="@string/widget_settings_title"
            android:excludeFromRecents="true"
            android:finishOnTaskLaunch="true"
            android:noHistory="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_CONFIGURE" />
            </intent-filter>
        </activity>

        <activity
            android:name=".widgets.customButtonsWidget.WidgetActionActivity"
            android:exported="true"
            android:excludeFromRecents="true"
            android:noHistory="true"
            android:theme="@style/Theme.QuickSearch" />

        <!-- Widget Receivers -->
        <receiver
            android:name=".widgets.searchWidget.SearchWidgetReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="android.intent.action.CONFIGURATION_CHANGED" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_info" />
        </receiver>

        <receiver
            android:name=".widgets.customButtonsWidget.CustomButtonsWidgetReceiver"
            android:exported="false"
            android:label="@string/widget_custom_buttons_widget_title">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="android.intent.action.CONFIGURATION_CHANGED" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/custom_buttons_widget_info" />
        </receiver>

        <!-- Quick Settings Tile Service -->
        <service
            android:name=".tile.QuickSearchTileService"
            android:exported="true"
            android:icon="@drawable/ic_widget_search"
            android:label="@string/app_name"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.emoji2.text.EmojiCompatInitializer"
                tools:node="remove" />
        </provider>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
